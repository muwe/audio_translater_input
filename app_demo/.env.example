# ============================================================
# Audio Translate Input — 环境变量示例（copy to .env / 复制为 .env）
# ============================================================

# ── API Keys — fill in at least one region's keys ────────────
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here   # optional fallback (sk-proj-... format)

# ── ASR Configuration ─────────────────────────────────────────
ASR_CN_URL=https://api.siliconflow.cn/v1/audio/transcriptions
ASR_CN_MODEL=FunAudioLLM/SenseVoiceSmall
ASR_US_URL=https://api.groq.com/openai/v1/audio/transcriptions
ASR_US_MODEL=whisper-large-v3
# ASR_FALLBACK_URL=https://api.openai.com/v1/audio/transcriptions
# ASR_FALLBACK_MODEL=whisper-1

# ── LLM Configuration ─────────────────────────────────────────
LLM_CN_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_CN_MODEL=Qwen/Qwen2.5-32B-Instruct
LLM_US_URL=https://openrouter.ai/api/v1/chat/completions
LLM_US_MODEL=openai/gpt-4o-mini
# LLM_FALLBACK_URL=https://api.openai.com/v1/chat/completions
# LLM_FALLBACK_MODEL=gpt-4o-mini
